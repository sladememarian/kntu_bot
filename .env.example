# ==========================================
# KNTU Bot 25 - Configuration
# ==========================================

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Google Gemini API Key (free from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Bot Admin User IDs (comma-separated Telegram user IDs)
ADMIN_IDS=123456789,987654321

# News channels to monitor (comma-separated channel usernames without @)
NEWS_CHANNELS=channel1,channel2,channel3

# Language setting: fa (Persian) or en (English) — default is fa
DEFAULT_LANG=fa

# Debug mode: true or false
DEBUG=false
